# Required for Homer text and voice generation.
OPENAI_API_KEY=

# Optional explicit overrides. These are the current defaults.
HOMER_MODEL=gpt-5.6-sol
HOMER_AUDIO_MODEL=gpt-4o-mini-tts

# Divine Presence uses a separate model and never silently falls back to Homer.
DIVINE_MODEL=gpt-5.6-terra

# Luna threshold encounters use a separate fixed character model.
LUNA_MODEL=gpt-5.6-luna
